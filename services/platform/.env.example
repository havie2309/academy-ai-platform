USER_MANAGEMENT_PORT=3001
USER_MANAGEMENT_URL=http://127.0.0.1:3001
CHAT_PORT=3002
CHAT_URL=http://127.0.0.1:3002
RBAC_PORT=3003
RBAC_URL=http://127.0.0.1:3003
ADMIN_CONFIG_PORT=3004
ADMIN_CONFIG_URL=http://127.0.0.1:3004
AUDIT_PORT=3005
AUDIT_URL=http://127.0.0.1:3005
ADMIN_SERVICE_LOG_DIRS=
APP_PORT=3000
JWT_SECRET=your-super-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_CONFIG_INTERNAL_KEY=change-me-before-enabling-internal-policy-fetch
ADMIN_CONFIG_CACHE_TTL_SECONDS=30
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
CHAT_SESSION_CONTEXT_TTL=3600
CHAT_SESSION_CONTEXT_MAX_MESSAGES=20
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=pm2
POSTGRES_USER=pm2_user
POSTGRES_PASSWORD=pm2pass
SQL_READONLY_USER=pm2_readonly
SQL_READONLY_PASSWORD=pm2_readonly_pass
SQL_STATEMENT_TIMEOUT_MS=10000
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DB=pm2
MONGO_USER=pm2_user
MONGO_PASSWORD=pm2pass
# LLM provider cho chat service: 'ollama' (local) hoặc 'openai' (cloud)
LLM_PROVIDER=ollama
# Ollama OpenAI-compatible endpoint + model (mặc định khi LLM_PROVIDER=ollama)
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_MODEL=
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_BACKOFF_MS=300
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_TIMEOUT=30
LLM_CIRCUIT_HALFOPEN_MAX=1
# Text-to-SQL có thể dùng model riêng; hiện tại dùng cùng baseline qwen2.5:3b
SQL_LLM_PROVIDER=ollama
SQL_LLM_BASE_URL=http://localhost:11434
SQL_LLM_MODEL=qwen2.5:3b
SQL_LLM_FALLBACK_PROVIDER=
SQL_LLM_FALLBACK_BASE_URL=
SQL_LLM_FALLBACK_MODEL=
SQL_OPENAI_MODEL=gpt-4o-mini
SQL_FEW_SHOT_ENABLED=true
# OpenAI cloud (chỉ dùng khi LLM_PROVIDER=openai) — chỉ server chat, không đặt VITE_ trên web-ui
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
WEB_URL=http://127.0.0.1:5174,http://localhost:5174
GATEWAY_TRUST_PROXY=false
NETWORK_RESTRICTED_PATHS=/api/etl
# Leave country policy disabled by default until reverse proxy / ingress can inject
# a trusted ISO-3166-1 alpha-2 country code header.
NETWORK_COUNTRY_HEADER=x-geo-country
NETWORK_ALLOWED_COUNTRIES=
NETWORK_BLOCKED_COUNTRIES=
# RAG pipeline
RAG_ENGINE_URL=http://localhost:8000
RAG_ENABLED=true
EMBEDDING_BASE_URL=http://localhost:8001
EMBEDDING_FALLBACK_BASE_URLS=
EMBEDDING_RETRY_ATTEMPTS=3
EMBEDDING_RETRY_BACKOFF_MS=400
EMBEDDING_CIRCUIT_FAILURE_THRESHOLD=5
EMBEDDING_CIRCUIT_TIMEOUT=30
EMBEDDING_CIRCUIT_HALFOPEN_MAX=1
RERANK_BASE_URL=http://localhost:8002
RERANK_FALLBACK_BASE_URLS=
RERANK_ENABLED=true
RERANK_RETRY_ATTEMPTS=2
RERANK_RETRY_BACKOFF_MS=250
RERANK_CIRCUIT_FAILURE_THRESHOLD=5
RERANK_CIRCUIT_TIMEOUT=30
RERANK_CIRCUIT_HALFOPEN_MAX=1
RETRIEVAL_TOP_K=60
RERANK_TOP_K=6
MAX_CHUNKS_PER_DOC=2
RERANK_DOC_MAX_CHARS=1800
RAG_CONTEXT_MAX_CHARS=1800
VECTOR_SCORE_MIN=-100
RERANK_SCORE_MIN=-0.5
RERANK_SCORE_DELTA=2
DOCUMENT_PROCESSOR_URL=http://localhost:8003
ETL_URL=http://localhost:8004
ETL_SYNC_URL=http://localhost:8004
ETL_INTERNAL_AUTH_HEADER=x-etl-internal-secret
ETL_INTERNAL_SHARED_SECRET=change-me-for-internal-gateway-etl-calls
GATEWAY_INTERNAL_SHARED_SECRET=change-me-for-internal-gateway-backend-calls
ETL_SCHEDULER_ENABLED=true
ETL_SCHEDULER_POLL_SECONDS=15
ETL_BATCH_MAX_SIZE=500
ETL_BATCH_MAX_LINEAGE_ROWS=100
CHUNK_MAX_PARENT_SIZE=1000
CHUNK_MAX_CHILD_SIZE=200
CHUNK_OVERLAP=0.2
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=pm2_user
RABBITMQ_PASSWORD=pm2pass
INGEST_QUEUE=ingest.jobs
MILVUS_HOST=localhost
MILVUS_PORT=19530
EMBEDDING_DIM=384
ETL_STORE_BACKEND=postgres
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

ALLOW_ADVERSARIAL_DOCS=true

RATE_LIMIT_AUTH=60
RATE_LIMIT_ANON=10
RATE_LIMIT_WINDOW=60
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION=900
LOGIN_LOCK_WINDOW=900
LOGIN_ADMIN_BYPASS_ROLES=ADMIN,BGD,P2,P7
RATE_LIMIT_ROLE_ADMIN=180
RATE_LIMIT_ROLE_BGD=180
RATE_LIMIT_ROLE_P2=120
RATE_LIMIT_ROLE_P7=90
RATE_LIMIT_ROLE_GIANG_VIEN=90
RATE_LIMIT_ROLE_HOC_VIEN=60
LOAD_SHEDDING_MAX_CONCURRENT=100
LOAD_SHEDDING_RETRY_AFTER=1

CIRCUIT_FAILURE_THRESHOLD_USERMGMT=5
CIRCUIT_FAILURE_THRESHOLD_CHAT=5
CIRCUIT_FAILURE_THRESHOLD_RAG=5
CIRCUIT_FAILURE_THRESHOLD_RBAC=5
CIRCUIT_FAILURE_THRESHOLD_ADMIN_CONFIG=5
CIRCUIT_FAILURE_THRESHOLD_AUDIT=5

CIRCUIT_TIMEOUT_USERMGMT=30
CIRCUIT_TIMEOUT_CHAT=30
CIRCUIT_TIMEOUT_RAG=30
CIRCUIT_TIMEOUT_RBAC=30
CIRCUIT_TIMEOUT_ADMIN_CONFIG=30
CIRCUIT_TIMEOUT_AUDIT=30

CIRCUIT_HALFOPEN_MAX_USERMGMT=1
CIRCUIT_HALFOPEN_MAX_CHAT=1
CIRCUIT_HALFOPEN_MAX_RAG=1
CIRCUIT_HALFOPEN_MAX_RBAC=1
CIRCUIT_HALFOPEN_MAX_ADMIN_CONFIG=1
CIRCUIT_HALFOPEN_MAX_AUDIT=1

GUARDRAIL_SEMANTIC_ENABLED=true

# Summarization (dedicated config, falls back to LLM_* if not set)
SUMMARY_MAX_CHARS=1500
SUMMARY_LLM_PROVIDER=ollama
SUMMARY_LLM_BASE_URL=http://localhost:11434
SUMMARY_LLM_MODEL=qwen2.5:3b
SUMMARY_LLM_FALLBACK_PROVIDER=
SUMMARY_LLM_FALLBACK_BASE_URL=
SUMMARY_LLM_FALLBACK_MODEL=
SUMMARY_LLM_RETRY_ATTEMPTS=2
