USER_MANAGEMENT_PORT=3001
USER_MANAGEMENT_URL=http://127.0.0.1:3001
CHAT_PORT=3002
CHAT_URL=http://127.0.0.1:3002
RBAC_PORT=3003
RBAC_URL=http://127.0.0.1:3003
ADMIN_CONFIG_PORT=3004
ADMIN_CONFIG_URL=http://127.0.0.1:3004
AUDIT_PORT=3005
AUDIT_URL=http://127.0.0.1:3005
APP_PORT=3000
JWT_SECRET=your-super-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_CONFIG_INTERNAL_KEY=change-me-before-enabling-internal-policy-fetch
ADMIN_CONFIG_CACHE_TTL_SECONDS=30
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
CHAT_SESSION_CONTEXT_TTL=3600
CHAT_SESSION_CONTEXT_MAX_MESSAGES=20
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=pm2
POSTGRES_USER=pm2_user
POSTGRES_PASSWORD=pm2pass
SQL_READONLY_USER=pm2_readonly
SQL_READONLY_PASSWORD=pm2_readonly_pass
SQL_STATEMENT_TIMEOUT_MS=10000
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DB=pm2
MONGO_USER=pm2_user
MONGO_PASSWORD=pm2pass
# LLM provider cho chat service: 'ollama' (local) hoặc 'openai' (cloud)
LLM_PROVIDER=ollama
# Ollama OpenAI-compatible endpoint + model (mặc định khi LLM_PROVIDER=ollama)
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
# Text-to-SQL có thể dùng model riêng; hiện tại dùng cùng baseline qwen2.5:3b
SQL_LLM_PROVIDER=ollama
SQL_LLM_BASE_URL=http://localhost:11434
SQL_LLM_MODEL=qwen2.5:3b
SQL_OPENAI_MODEL=gpt-4o-mini
SQL_FEW_SHOT_ENABLED=true
# OpenAI cloud (chỉ dùng khi LLM_PROVIDER=openai) — chỉ server chat, không đặt VITE_ trên web-ui
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
WEB_URL=http://127.0.0.1:5174,http://localhost:5174
# RAG pipeline
RAG_ENGINE_URL=http://localhost:8000
RAG_ENABLED=true
EMBEDDING_BASE_URL=http://localhost:8001
RERANK_BASE_URL=http://localhost:8002
RERANK_ENABLED=true
RETRIEVAL_TOP_K=30
RERANK_TOP_K=8
MAX_CHUNKS_PER_DOC=3
VECTOR_SCORE_MIN=0.15
RERANK_SCORE_MIN=-8
RERANK_SCORE_DELTA=4
DOCUMENT_PROCESSOR_URL=http://localhost:8003
ETL_SYNC_URL=http://localhost:8004
ETL_SCHEDULER_ENABLED=true
ETL_SCHEDULER_POLL_SECONDS=15
ETL_BATCH_MAX_SIZE=500
ETL_BATCH_MAX_LINEAGE_ROWS=100
CHUNK_MAX_SIZE=500
CHUNK_OVERLAP=0.2
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=pm2_user
RABBITMQ_PASSWORD=pm2pass
INGEST_QUEUE=ingest.jobs
MILVUS_HOST=localhost
MILVUS_PORT=19530
EMBEDDING_DIM=384
ETL_STORE_BACKEND=postgres
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
RATE_LIMIT_AUTH=60
RATE_LIMIT_ANON=10
LOAD_SHEDDING_MAX_CONCURRENT=100

CIRCUIT_FAILURE_THRESHOLD_USERMGMT=5
CIRCUIT_FAILURE_THRESHOLD_CHAT=5
CIRCUIT_FAILURE_THRESHOLD_RAG=5
CIRCUIT_FAILURE_THRESHOLD_RBAC=5
CIRCUIT_FAILURE_THRESHOLD_ADMIN_CONFIG=5
CIRCUIT_FAILURE_THRESHOLD_AUDIT=5

CIRCUIT_TIMEOUT_USERMGMT=30
CIRCUIT_TIMEOUT_CHAT=30
CIRCUIT_TIMEOUT_RAG=30
CIRCUIT_TIMEOUT_RBAC=30
CIRCUIT_TIMEOUT_ADMIN_CONFIG=30
CIRCUIT_TIMEOUT_AUDIT=30

CIRCUIT_HALFOPEN_MAX_USERMGMT=1
CIRCUIT_HALFOPEN_MAX_CHAT=1
CIRCUIT_HALFOPEN_MAX_RAG=1
CIRCUIT_HALFOPEN_MAX_RBAC=1
CIRCUIT_HALFOPEN_MAX_ADMIN_CONFIG=1
CIRCUIT_HALFOPEN_MAX_AUDIT=1