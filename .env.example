# ================================
# DATABASE
# ================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pm2
POSTGRES_USER=pm2_user
POSTGRES_PASSWORD=pm2pass

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=pm2
MONGO_USER=pm2_user
MONGO_PASSWORD=pm2pass

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=pm2_user
RABBITMQ_PASSWORD=pm2pass

MILVUS_HOST=localhost
MILVUS_PORT=19530

# ================================
# AI SERVICES (1 máy: localhost)
# ================================
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
EMBEDDING_BASE_URL=http://localhost:8001
RERANK_BASE_URL=http://localhost:8002

# ================================
# APP
# ================================
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h
APP_PORT=3000
USER_MANAGEMENT_PORT=3001
WEB_URL=http://localhost:5173
ETL_URL=http://localhost:8004
ETL_INTERNAL_AUTH_HEADER=x-etl-internal-secret
ETL_INTERNAL_SHARED_SECRET=change-me-for-internal-gateway-etl-calls

ALLOW_ADVERSARIAL_DOCS=true

# Web UI (services/web-ui/.env.local) — không chứa OpenAI key
VITE_MOCK_AUTH=false
VITE_API_URL=http://localhost:3000
VITE_REQUIRE_AUTH=true

# OpenAI tạm: đặt OPENAI_API_KEY trong services/platform/.env (server-only)

RATE_LIMIT_AUTH=60
RATE_LIMIT_ANON=10
LOAD_SHEDDING_MAX_CONCURRENT=100

CIRCUIT_FAILURE_THRESHOLD_USERMGMT=5
CIRCUIT_FAILURE_THRESHOLD_CHAT=5
CIRCUIT_FAILURE_THRESHOLD_RAG=5
CIRCUIT_FAILURE_THRESHOLD_RBAC=5
CIRCUIT_FAILURE_THRESHOLD_ADMIN_CONFIG=5
CIRCUIT_FAILURE_THRESHOLD_AUDIT=5

CIRCUIT_TIMEOUT_USERMGMT=30
CIRCUIT_TIMEOUT_CHAT=30
CIRCUIT_TIMEOUT_RAG=30
CIRCUIT_TIMEOUT_RBAC=30
CIRCUIT_TIMEOUT_ADMIN_CONFIG=30
CIRCUIT_TIMEOUT_AUDIT=30

CIRCUIT_HALFOPEN_MAX_USERMGMT=1
CIRCUIT_HALFOPEN_MAX_CHAT=1
CIRCUIT_HALFOPEN_MAX_RAG=1
CIRCUIT_HALFOPEN_MAX_RBAC=1
CIRCUIT_HALFOPEN_MAX_ADMIN_CONFIG=1
CIRCUIT_HALFOPEN_MAX_AUDIT=1
