USER_MANAGEMENT_PORT=3001
USER_MANAGEMENT_URL=http://localhost:3001
CHAT_PORT=3002
CHAT_URL=http://localhost:3002
APP_PORT=3000
JWT_SECRET=your-super-secret-change-in-production
JWT_EXPIRES_IN=8h
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=pm2
POSTGRES_USER=pm2_user
POSTGRES_PASSWORD=pm2pass
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=pm2
MONGO_USER=pm2_user
MONGO_PASSWORD=pm2pass
# LLM provider cho chat service: 'ollama' (local) hoặc 'openai' (cloud)
LLM_PROVIDER=ollama
# Ollama OpenAI-compatible endpoint + model (mặc định khi LLM_PROVIDER=ollama)
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
# OpenAI cloud (chỉ dùng khi LLM_PROVIDER=openai) — chỉ server chat, không đặt VITE_ trên web-ui
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
WEB_URL=http://localhost:5173
